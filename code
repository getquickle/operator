    full: [
      { id: 'warmup', text: 'Warmup — 10 min easy jog OR brisk walk' },
      { id: 'pick-format', text: 'Pick ONE format and stick with it', detail: 'Outdoor running · Treadmill · Hill repeats · Stairs. Complete all 8 rounds in the chosen format.' },
      { id: 'int-1', text: 'Interval 1 — 1 min HARD / 2 min EASY', detail: 'HARD = 8/10 effort, can\'t hold conversation. EASY = walk or very slow jog.' },
      { id: 'int-2', text: 'Interval 2 — 1 min HARD / 2 min EASY' },
      { id: 'int-3', text: 'Interval 3 — 1 min HARD / 2 min EASY' },
      { id: 'int-4', text: 'Interval 4 — 1 min HARD / 2 min EASY' },
      { id: 'int-5', text: 'Interval 5 — 1 min HARD / 2 min EASY' },
      { id: 'int-6', text: 'Interval 6 — 1 min HARD / 2 min EASY' },
      { id: 'int-7', text: 'Interval 7 — 1 min HARD / 2 min EASY' },
      { id: 'int-8', text: 'Interval 8 — 1 min HARD / 2 min EASY', detail: 'Final round.' },
      { id: 'cooldown', text: 'Cooldown — 10 min easy walk' },
    ],
    reduced: [
      { id: 'walk-r', text: '40 min brisk walk' },
    ],
  },

  wednesday: 'monday', // identical

  thursday: {
    mission: 'Long Engine Session',
    full: [
      { id: 'z2', text: '60–75 min continuous Zone 2', detail: 'Approved: brisk outdoor walk · incline treadmill · easy trail hike · easy jog if joints tolerate. Conversational pace. Elevated but controlled breathing. No stopping unless emergency.' },
    ],
    reduced: [
      { id: 'walk-r', text: '40 min brisk walk' },
    ],
  },

  friday: 'monday', // identical

  saturday: {
    mission: 'Mountain Session',
    full: [
      { id: 'pack', text: 'Pack: water + electrolytes', detail: 'If session > 90 min, also bring fuel.' },
      { id: 'mtn', text: '90–240 min mountain effort', detail: 'Approved: steep trail hike · hike/run hybrid · trail run. MINIMUM 1,500 ft elevation gain. No casual neighborhood strolls.' },
    ],
    reduced: [
      { id: 'pack-r', text: 'Pack: water + electrolytes' },
      { id: 'mtn-r', text: '60 min steep hike — minimum', detail: 'Still mandatory.' },
    ],
  },

  sunday: {
