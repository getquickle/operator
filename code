/* ============================================================
   SLEEP GATE
   ============================================================ */

function renderSleepGate() {
  const gate = el('div', { class: 'gate' });
  gate.appendChild(el('div', { class: 'gate-sub' }, 'First decision of the day'));
  gate.appendChild(el('h2', { class: 'gate-q' }, 'Did you get at least 5 total hours of sleep?'));
  const btns = el('div', { class: 'gate-btns' });
  const yes = el('button', { class: 'gate-btn', onclick: () => setSleep('yes') }, 'YES', el('small', null, 'Full plan'));
  const no  = el('button', { class: 'gate-btn', onclick: () => setSleep('no') },  'NO',  el('small', null, 'Reduced plan'));
  btns.appendChild(yes); btns.appendChild(no);
  gate.appendChild(btns);
  return gate;
}

function renderSleepStatus() {
  const today = getToday();
  const mode = today.sleep === 'yes' ? 'FULL' : 'REDUCED';
  const sub  = today.sleep === 'yes' ? 'Slept ≥ 5h' : 'Slept < 5h';
  const wrap = el('div', { class: 'sleep-status' });
  wrap.appendChild(el('div', { class: 'sleep-status-text', html: `${sub} <span style="color:var(--text-faint)">/</span> Plan mode: <b>${mode}</b>` }));
  wrap.appendChild(el('button', { onclick: () => { today.sleep = null; saveStore(store); render(); showToast('Sleep status cleared'); } }, 'Change'));
