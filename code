<script>
/* ============================================================
   STATE & STORAGE
   ============================================================ */
const STORAGE_KEY = 'quickle_v1';
const DAY_NAMES = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];
const DAY_DISPLAY = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function todayKey() {
  const d = new Date();
  return d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0') + '-' + String(d.getDate()).padStart(2,'0');
}
function dayName() { return DAY_NAMES[new Date().getDay()]; }

function loadStore() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return defaultStore();
    const parsed = JSON.parse(raw);
    return Object.assign(defaultStore(), parsed);
  } catch (e) {
    return defaultStore();
  }
}
function defaultStore() {
  return {
    history: {},                        // { '2026-05-23': { sleep, checks: {id:true}, mission, mode } }
    settings: { snack: null, units: 'imperial' },
  };
}
function saveStore(s) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
}
let store = loadStore();

function getToday() {
  const k = todayKey();
  if (!store.history[k]) {
    store.history[k] = { sleep: null, checks: {} };
  }
  return store.history[k];
}

/* ============================================================
   PLAN DATA — verbatim from spec
   ============================================================ */

const TRAINING_PLANS = {
  monday: {
    mission: 'Foundation Session',
    full: [
      { id: 'walk', text: '40 min brisk walk', detail: 'Outdoors preferred. Incline preferred. Treadmill acceptable @ 8–12% incline, 3.0–3.8 mph. Breathing elevated. Conversation still possible.' },
      { id: 'circuit-1', text: 'Round 1 — circuit', rounds: ['15 pushups','20 air squats','10 lunges each leg','30 sec plank'], detail: '60 sec rest before round 2.' },
      { id: 'circuit-2', text: 'Round 2 — circuit', rounds: ['15 pushups','20 air squats','10 lunges each leg','30 sec plank'], detail: '60 sec rest before round 3.' },
      { id: 'circuit-3', text: 'Round 3 — circuit', rounds: ['15 pushups','20 air squats','10 lunges each leg','30 sec plank'], detail: 'Final round. Finish strong.' },
    ],
    reduced: [
      { id: 'walk-r', text: '20 min brisk walk' },
      { id: 'circuit-r1', text: 'Round 1 — circuit', rounds: ['10 pushups','15 squats','8 lunges each leg','20 sec plank'] },
      { id: 'circuit-r2', text: 'Round 2 — circuit', rounds: ['10 pushups','15 squats','8 lunges each leg','20 sec plank'] },
    ],
  },

  tuesday: {
