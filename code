  sum.appendChild(el('div', { class: 'collapse-chev' }, '+'));
  note.appendChild(sum);
  note.appendChild(el('div', { class: 'collapse-body', html: '<p><strong>Allowed:</strong> protein shake in water. <strong>Nothing else.</strong></p>' }));
  sec.appendChild(note);

  // Banned foods
  const banned = el('details', { class: 'collapse' });
  const bsum = el('summary');
  bsum.appendChild(el('div', { class: 'collapse-title', html: '<span class="glyph">✕</span>Banned foods' }));
  bsum.appendChild(el('div', { class: 'collapse-chev' }, '+'));
  banned.appendChild(bsum);
  const bbody = el('div', { class: 'collapse-body' });
  bbody.appendChild(el('p', { html: '<strong>Rule:</strong> if it\'s not on the meal list, don\'t eat it.' }));
  const grid = el('div', { class: 'banned-grid' });
  BANNED.forEach(b => grid.appendChild(el('span', null, b)));
  bbody.appendChild(grid);
  banned.appendChild(bbody);
  sec.appendChild(banned);

  return sec;
