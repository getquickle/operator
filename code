}

function setSleep(answer) {
  const today = getToday();
  today.sleep = answer;
  // If switching modes, clear training-specific checks
  Object.keys(today.checks).forEach(k => {
    if (k.startsWith('circuit') || k.startsWith('int-') || k.startsWith('walk') || k === 'warmup' || k === 'cooldown' || k === 'z2' || k === 'mtn' || k === 'mtn-r' || k === 'pack' || k === 'pack-r' || k === 'mob' || k === 'mob-r' || k === 'pick-format') {
      delete today.checks[k];
    }
  });
  saveStore(store);
  render();
  showToast(answer === 'yes' ? 'Full plan loaded' : 'Reduced plan loaded');
}

/* ============================================================
   INTERACTION
   ============================================================ */

function toggleCheck(id) {
  const today = getToday();
  today.checks[id] = !today.checks[id];
  saveStore(store);
  // Targeted DOM update (faster than full re-render)
  document.querySelectorAll(`[data-id="${id}"]`).forEach(node => {
    node.classList.toggle('checked', !!today.checks[id]);
  });
  updateProgress();
  updateStreak();
}

/* ============================================================
   PROGRESS + STREAK
   ============================================================ */

function getActiveTaskIds() {
  const today = getToday();
  const day = dayName();
  const plan = getPlan(day);
  const mode = today.sleep === 'yes' ? 'full' : 'reduced';
  const ids = [];

  MORNING_TRIGGER.forEach(t => ids.push(t.id));
  plan[mode].forEach(t => ids.push(t.id));
  MEALS.forEach(m => ids.push(m.id));
  if (day === 'saturday') { ids.push('wk-weigh','wk-measure'); }
  return ids;
}

function updateProgress() {
  const today = getToday();
  if (today.sleep === null) {
    document.getElementById('prog-fill').style.width = '0%';
    document.getElementById('prog-pct').textContent = '—';
    document.getElementById('prog-pct').classList.remove('complete');
    return;
  }
  const ids = getActiveTaskIds();
  const done = ids.filter(id => today.checks[id]).length;
  const pct = ids.length ? Math.round((done / ids.length) * 100) : 0;
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('prog-pct').textContent = pct + '%';
  document.getElementById('prog-pct').classList.toggle('complete', pct === 100);

  // Show / refresh complete banner
  const existing = document.getElementById('complete-banner');
  if (pct === 100) {
    if (!existing) {
      const c = el('div', { class: 'complete-banner', id: 'complete-banner' });
      c.appendChild(el('h3', null, 'Mission complete.'));
      c.appendChild(el('p', null, 'Day logged. Hold the line tomorrow.'));
      const content = document.getElementById('content');
      content.insertBefore(c, content.firstChild);
    }
  } else if (existing) {
    existing.remove();
  }
}

function computeStreak() {
  // Count consecutive days ending today (or yesterday if today not yet started) where day was 100%.
  const days = Object.keys(store.history).sort();
  let streak = 0;
  const oneDay = 86400000;
  let cursor = new Date();
  cursor.setHours(0,0,0,0);

  // If today is not 100%, we still count the streak up to yesterday.
  const todayK = todayKey();
  const today = store.history[todayK];
  const todayDone = today && isDayComplete(todayK);
  if (!todayDone) {
    cursor = new Date(cursor.getTime() - oneDay);
  }

  while (true) {
    const k = cursor.getFullYear() + '-' + String(cursor.getMonth()+1).padStart(2,'0') + '-' + String(cursor.getDate()).padStart(2,'0');
    if (isDayComplete(k)) {
      streak++;
      cursor = new Date(cursor.getTime() - oneDay);
    } else break;
    if (streak > 365) break;
  }
  return streak;
}

function isDayComplete(dateKey) {
  const data = store.history[dateKey];
  if (!data || !data.sleep) return false;
  // Determine day-of-week from key
  const d = new Date(dateKey + 'T12:00:00');
  const dn = DAY_NAMES[d.getDay()];
  const plan = getPlan(dn);
  const mode = data.sleep === 'yes' ? 'full' : 'reduced';
  const ids = [];
  MORNING_TRIGGER.forEach(t => ids.push(t.id));
  plan[mode].forEach(t => ids.push(t.id));
  MEALS.forEach(m => ids.push(m.id));
  if (dn === 'saturday') { ids.push('wk-weigh','wk-measure'); }
  return ids.every(id => data.checks && data.checks[id]);
}

function updateStreak() {
  const s = computeStreak();
  document.getElementById('stat-streak').innerHTML = s + '<span class="unit">d</span>';
}

/* ============================================================
   HEADER + STATS
   ============================================================ */

function updateHeader() {
  const now = new Date();
  const day = dayName();
  const idx = now.getDay();
  document.getElementById('hero-day').innerHTML = DAY_DISPLAY[idx] + '<em>.</em>';

  // Day of program — count from first entry
  const allDates = Object.keys(store.history).sort();
  const firstDate = allDates[0] || todayKey();
  const start = new Date(firstDate + 'T12:00:00');
  const today = new Date(todayKey() + 'T12:00:00');
  const dayNum = Math.floor((today - start) / 86400000) + 1;
  const weekNum = Math.ceil(dayNum / 7);
  document.getElementById('hero-daynum').textContent = String(dayNum).padStart(2,'0');
  document.getElementById('hero-week').textContent = 'Week ' + String(weekNum).padStart(2,'0');

  // Mission
  const plan = getPlan(day);
  const heroMission = document.getElementById('hero-mission');
  heroMission.innerHTML = '<span class="bar"></span><span>' + plan.mission.toUpperCase() + '</span>';

  // Mode
  const todayData = getToday();
  const stateMode = document.getElementById('stat-mode');
  if (todayData.sleep === null) {
    stateMode.textContent = '—';
    stateMode.classList.remove('accent','moss');
    stateMode.classList.add('muted');
  } else if (todayData.sleep === 'yes') {
    stateMode.textContent = 'FULL';
    stateMode.classList.remove('muted','moss');
    stateMode.classList.add('accent');
  } else {
    stateMode.textContent = 'REDUCED';
    stateMode.classList.remove('muted','accent');
    stateMode.classList.add('moss');
  }

  // Meta time/date
  document.getElementById('meta-date').textContent = todayKey();
  document.getElementById('meta-time').textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });

  // Target with units
  const targetEl = document.getElementById('stat-target');
  if (store.settings.units === 'metric') {
    targetEl.innerHTML = '88<span class="unit">kg</span>';
  } else {
    targetEl.innerHTML = '195<span class="unit">lb</span>';
  }
}

/* ============================================================
   MAIN RENDER
   ============================================================ */

function render() {
  const content = document.getElementById('content');
  content.innerHTML = '';
  const today = getToday();

  if (today.sleep === null) {
    content.appendChild(renderSleepGate());
    content.appendChild(renderRules());
    content.appendChild(renderEmergency());
  } else {
    content.appendChild(renderSleepStatus());
    content.appendChild(renderMorningSection());
    content.appendChild(renderTrainingSection());
    content.appendChild(renderMealsSection());
    content.appendChild(renderRules());
    const wk = renderWeeklyCheck();
    if (wk) content.appendChild(wk);
    content.appendChild(renderEmergency());
  }

  updateHeader();
  updateProgress();
  updateStreak();
}

/* ============================================================
   SETTINGS MODAL
   ============================================================ */

function openSettings() {
  document.getElementById('modal-settings').classList.add('open');
  syncSettingsUI();
}
function closeSettings() {
  document.getElementById('modal-settings').classList.remove('open');
}
function syncSettingsUI() {
  document.querySelectorAll('#opt-snack button').forEach(b => {
    b.classList.toggle('active', b.dataset.val === store.settings.snack);
  });
  document.querySelectorAll('#opt-units button').forEach(b => {
    b.classList.toggle('active', b.dataset.val === store.settings.units);
  });
}

document.getElementById('btn-settings').addEventListener('click', openSettings);
document.getElementById('settings-close').addEventListener('click', closeSettings);
document.getElementById('modal-settings').addEventListener('click', (e) => {
  if (e.target.id === 'modal-settings') closeSettings();
});

document.querySelectorAll('#opt-snack button').forEach(b => {
  b.addEventListener('click', () => {
    store.settings.snack = b.dataset.val;
    saveStore(store);
    syncSettingsUI();
    render();
    showToast('Snack locked: ' + (b.dataset.val === 'yogurt' ? 'Greek yogurt' : 'Hard-boiled eggs'));
  });
});

document.querySelectorAll('#opt-units button').forEach(b => {
  b.addEventListener('click', () => {
    store.settings.units = b.dataset.val;
    saveStore(store);
    syncSettingsUI();
    updateHeader();
  });
});

document.getElementById('btn-reset-today').addEventListener('click', () => {
  if (!confirm('Reset today\'s progress? Sleep answer and all checks will clear for today only.')) return;
  store.history[todayKey()] = { sleep: null, checks: {} };
  saveStore(store);
  closeSettings();
  render();
  showToast('Today reset');
});

document.getElementById('btn-reset-all').addEventListener('click', () => {
  if (!confirm('Wipe ALL data including streak history and settings? This cannot be undone.')) return;
  if (!confirm('Are you sure? Final warning.')) return;
  localStorage.removeItem(STORAGE_KEY);
  store = defaultStore();
  closeSettings();
  render();
  showToast('All data wiped');
});

/* ============================================================
   TOAST
   ============================================================ */

let toastTimer = null;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

/* ============================================================
   KEYBOARD SHORTCUTS
   ============================================================ */
document.addEventListener('keydown', (e) => {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
  if (e.key === 's' || e.key === 'S') { openSettings(); }
  if (e.key === 'Escape') { closeSettings(); }
});

/* ============================================================
   MIDNIGHT WATCH — auto-roll to next day
   ============================================================ */
let lastDate = todayKey();
setInterval(() => {
  const now = todayKey();
  if (now !== lastDate) {
    lastDate = now;
    // Ensure today's record exists for fresh day
    getToday();
    saveStore(store);
    render();
    showToast('New day. New mission.');
  }
  // Refresh clock display
  const tEl = document.getElementById('meta-time');
  if (tEl) tEl.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
}, 30000);

/* ============================================================
   INIT
   ============================================================ */
render();

// Ensure today's record initialized
getToday();
saveStore(store);
</script>

