<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#0c0d0e" />
<meta name="color-scheme" content="dark" />
<title>QUICKLE — Founder Ascent System</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ============================================================
   QUICKLE FOUNDER ASCENT SYSTEM
   Expedition execution dashboard
   ============================================================ */

:root {
  --bg:           #0c0d0e;
  --bg-elev:     #131418;
  --surface:     #181a1f;
  --surface-2:   #1f222a;
  --border:      #2b2f37;
  --border-soft: #22252c;

  --text:        #e8e3d6;
  --text-2:      #b8b1a0;
  --text-mute:   #6e6a5e;
  --text-faint:  #44423a;

  --accent:      #d97742;   /* alpenglow */
  --accent-dim:  #8a4a26;
  --accent-soft: rgba(217,119,66,0.10);

  --signal:      #b85c3c;   /* weathered red */
  --moss:        #7a9268;   /* completed */
  --cyan:        #5b8a99;   /* info */

  --grid:        rgba(255,255,255,0.025);

  --pad:         16px;
  --radius:      2px;

  --mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
  --serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
}

* { box-sizing: border-box; }

html, body { margin: 0; padding: 0; background: var(--bg); color: var(--text); }
body {
  font-family: var(--mono);
  font-size: 14px;
  line-height: 1.55;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  letter-spacing: 0.005em;
  padding-bottom: 100px;
  min-height: 100vh;
  position: relative;
  overflow-x: hidden;
}

/* ---------- topographic background ---------- */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background-image:
    radial-gradient(ellipse 1200px 800px at 80% -10%, rgba(217,119,66,0.06), transparent 60%),
    radial-gradient(ellipse 800px 600px at -10% 100%, rgba(91,138,153,0.04), transparent 60%);
}
body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  opacity: 0.18;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='800' height='800' viewBox='0 0 800 800'><g fill='none' stroke='%23a89e8a' stroke-width='0.4' opacity='0.4'><path d='M -50 420 Q 100 380 220 410 T 480 400 T 750 430 T 950 410'/><path d='M -50 440 Q 100 400 220 430 T 480 420 T 750 450 T 950 430'/><path d='M -50 470 Q 100 430 220 460 T 480 450 T 750 480 T 950 460'/><path d='M -50 510 Q 100 470 220 500 T 480 490 T 750 520 T 950 500'/><path d='M -50 560 Q 100 520 220 550 T 480 540 T 750 570 T 950 550'/><path d='M -50 620 Q 100 580 220 610 T 480 600 T 750 630 T 950 610'/><path d='M -50 690 Q 100 650 220 680 T 480 670 T 750 700 T 950 680'/><path d='M -50 200 Q 200 160 350 190 T 600 180 T 850 210'/><path d='M -50 220 Q 200 180 350 210 T 600 200 T 850 230'/><path d='M -50 250 Q 200 210 350 240 T 600 230 T 850 260'/><path d='M -50 290 Q 200 250 350 280 T 600 270 T 850 300'/><path d='M -50 340 Q 200 300 350 330 T 600 320 T 850 350'/></g></svg>");
  background-size: 1200px 1200px;
  background-position: center;
}

main { position: relative; z-index: 1; }

/* ---------- header / command bar ---------- */
.cmd {
  border-bottom: 1px solid var(--border);
  background: linear-gradient(180deg, rgba(19,20,24,0.85), rgba(12,13,14,0.85));
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  position: sticky;
  top: 0;
  z-index: 50;
}
.cmd-inner {
  max-width: 720px;
  margin: 0 auto;
  padding: 14px var(--pad) 16px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 8px;
  align-items: end;
}
.cmd-brand {
  font-family: var(--serif);
  font-weight: 400;
  font-size: 18px;
  letter-spacing: 0.02em;
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--text);
}
.cmd-brand .dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12px var(--accent), 0 0 24px var(--accent-dim);
  flex-shrink: 0;
}
.cmd-meta {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  color: var(--text-mute);
  text-transform: uppercase;
  text-align: right;
  line-height: 1.4;
}
.cmd-meta b { color: var(--text-2); font-weight: 500; }

/* ---------- container ---------- */
.wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 var(--pad);
}

/* ---------- hero ---------- */
.hero {
  padding: 32px 0 28px;
  border-bottom: 1px solid var(--border-soft);
}
.hero-eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.28em;
  color: var(--text-mute);
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
}
.hero-eyebrow .pipe { color: var(--text-faint); }
.hero-day {
  font-family: var(--serif);
  font-weight: 300;
  font-size: clamp(40px, 9vw, 64px);
  line-height: 0.95;
  letter-spacing: -0.02em;
  color: var(--text);
  margin: 0;
}
.hero-day em {
  font-style: italic;
  color: var(--accent);
  font-weight: 400;
}
.hero-mission {
  font-family: var(--mono);
  font-size: 12px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-2);
  margin-top: 14px;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 6px 10px;
  border: 1px solid var(--border);
  background: var(--surface);
}
.hero-mission .bar { width: 18px; height: 1px; background: var(--accent); }

/* ---------- stat strip ---------- */
.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--border-soft);
  border-bottom: 1px solid var(--border-soft);
  margin: 0 calc(-1 * var(--pad));
}
.stat {
  padding: 16px var(--pad);
  border-right: 1px solid var(--border-soft);
  position: relative;
}
.stat:last-child { border-right: none; }
.stat-label {
  font-size: 9px;
  letter-spacing: 0.22em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 6px;
}
.stat-value {
  font-family: var(--serif);
  font-weight: 400;
  font-size: 22px;
  color: var(--text);
  letter-spacing: -0.01em;
  line-height: 1;
}
.stat-value .unit {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-mute);
  letter-spacing: 0.12em;
  margin-left: 4px;
}
.stat-value.muted { color: var(--text-mute); }
.stat-value.accent { color: var(--accent); }
.stat-value.moss { color: var(--moss); }

/* ---------- sleep gate ---------- */
.gate {
  margin: 36px 0;
  padding: 28px 22px;
  border: 1px solid var(--border);
  background: var(--surface);
  position: relative;
}
.gate::before {
  content: 'SYS // 01';
  position: absolute;
  top: -1px; left: 14px;
  transform: translateY(-50%);
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.24em;
  background: var(--bg);
  padding: 0 8px;
  color: var(--accent);
}
.gate-q {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  line-height: 1.3;
  letter-spacing: -0.005em;
  margin: 0 0 18px;
  color: var(--text);
}
.gate-sub {
  font-size: 11px;
  color: var(--text-mute);
  letter-spacing: 0.08em;
  margin-bottom: 18px;
  text-transform: uppercase;
}
.gate-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}
.gate-btn {
  padding: 18px 14px;
  background: var(--bg-elev);
  border: 1px solid var(--border);
  color: var(--text);
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.15s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.gate-btn small {
  font-size: 9px;
  color: var(--text-mute);
  letter-spacing: 0.18em;
  font-weight: 400;
}
.gate-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-soft);
}
.gate-btn:hover small { color: var(--accent-dim); }
.gate-btn:active { transform: translateY(1px); }

.sleep-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 12px 14px;
  margin: 24px 0 8px;
  background: var(--surface);
  border: 1px solid var(--border-soft);
  border-left: 2px solid var(--accent);
}
.sleep-status-text {
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-2);
}
.sleep-status-text b { color: var(--accent); font-weight: 600; }
.sleep-status button {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-mute);
  background: transparent;
  border: 1px solid var(--border);
  padding: 6px 10px;
  cursor: pointer;
}
.sleep-status button:hover { color: var(--accent); border-color: var(--accent); }

/* ---------- section ---------- */
.section {
  margin: 28px 0;
  border: 1px solid var(--border-soft);
  background: rgba(20, 22, 26, 0.7);
}
.section-head {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-soft);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}
.section-head-left {
  display: flex;
  align-items: baseline;
  gap: 12px;
  min-width: 0;
}
.section-num {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--accent);
}
.section-title {
  font-family: var(--serif);
  font-size: 18px;
  font-weight: 400;
  letter-spacing: -0.005em;
  color: var(--text);
  margin: 0;
}
.section-title em {
  font-style: italic;
  color: var(--text-2);
  font-weight: 300;
}
.section-tag {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-mute);
  padding: 3px 8px;
  border: 1px solid var(--border);
  background: var(--bg);
  white-space: nowrap;
  flex-shrink: 0;
}
.section-tag.reduced { color: var(--signal); border-color: rgba(184,92,60,0.3); }
.section-tag.full { color: var(--moss); border-color: rgba(122,146,104,0.3); }
.section-body { padding: 10px 0 6px; }

/* ---------- checklist items ---------- */
.task {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 16px;
  cursor: pointer;
  border-top: 1px solid transparent;
  border-bottom: 1px solid var(--border-soft);
  user-select: none;
  -webkit-tap-highlight-color: transparent;
  transition: background 0.12s ease;
  min-height: 56px;
}
.section-body .task:last-child { border-bottom: none; }
.task:hover { background: rgba(255,255,255,0.015); }

.task-box {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  border: 1px solid var(--border);
  background: var(--bg-elev);
  margin-top: 2px;
  position: relative;
  transition: all 0.15s ease;
}
.task-box::after {
  content: '';
  position: absolute;
  inset: 4px;
  background: var(--accent);
  transform: scale(0);
  transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.task.checked .task-box {
  border-color: var(--accent);
  background: var(--accent-soft);
}
.task.checked .task-box::after { transform: scale(1); }
.task.checked .task-text { color: var(--text-mute); }
.task.checked .task-text strong { color: var(--text-2); text-decoration: line-through; text-decoration-color: var(--text-faint); }

.task-main { flex: 1; min-width: 0; }
.task-text {
  font-family: var(--mono);
  font-size: 14px;
  line-height: 1.45;
  color: var(--text);
  transition: color 0.15s ease;
}
.task-text strong { font-weight: 600; color: var(--text); }
.task-detail {
  font-size: 11px;
  color: var(--text-mute);
  line-height: 1.55;
  margin-top: 6px;
  letter-spacing: 0.01em;
}
.task-detail ul {
  margin: 4px 0 0;
  padding-left: 16px;
}
.task-detail ul li { margin-bottom: 2px; }

/* round indicator – grouped sub-items */
.task-rounds {
  margin-top: 8px;
  padding: 8px 10px;
  background: var(--bg-elev);
  border-left: 2px solid var(--accent-dim);
  font-size: 12px;
  color: var(--text-2);
}
.task-rounds-hd {
  font-size: 9px;
  letter-spacing: 0.22em;
  color: var(--text-mute);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.task-rounds ul {
  margin: 0;
  padding-left: 16px;
  list-style: none;
}
.task-rounds ul li {
  position: relative;
  padding-left: 0;
}
.task-rounds ul li::before {
  content: '—';
  color: var(--text-faint);
  position: absolute;
  left: -14px;
}

/* ---------- meal block ---------- */
.meal-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-soft);
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}
.section-body .meal-item:last-child { border-bottom: none; }
.meal-item:hover { background: rgba(255,255,255,0.015); }
.meal-time {
  flex-shrink: 0;
  width: 78px;
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.18em;
  color: var(--text-mute);
  text-transform: uppercase;
  padding-top: 4px;
}
.meal-time b {
  display: block;
  color: var(--accent);
  font-weight: 500;
  margin-bottom: 2px;
}
.meal-content { flex: 1; min-width: 0; display: flex; gap: 12px; }
.meal-content .task-box { margin-top: 4px; }
.meal-body { flex: 1; }
.meal-list {
  font-family: var(--mono);
  font-size: 13px;
  color: var(--text);
  line-height: 1.6;
}
.meal-list .b { color: var(--text-mute); margin-right: 6px; }
.meal-item.checked .meal-list { color: var(--text-mute); text-decoration: line-through; text-decoration-color: var(--text-faint); }
.meal-item.checked .task-box { border-color: var(--accent); background: var(--accent-soft); }
.meal-item.checked .task-box::after { transform: scale(1); }
.meal-note {
  font-size: 11px;
  color: var(--text-mute);
  margin-top: 6px;
  font-style: italic;
}

/* ---------- collapsibles ---------- */
.collapse {
  margin: 14px 0;
  border: 1px solid var(--border-soft);
  background: var(--bg-elev);
}
.collapse summary {
  list-style: none;
  cursor: pointer;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  -webkit-tap-highlight-color: transparent;
}
.collapse summary::-webkit-details-marker { display: none; }
.collapse-title {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-2);
}
.collapse-title .glyph { color: var(--accent); margin-right: 10px; }
.collapse-chev {
  color: var(--text-mute);
  font-family: var(--mono);
  font-size: 12px;
  transition: transform 0.2s ease;
}
.collapse[open] .collapse-chev { transform: rotate(45deg); color: var(--accent); }
.collapse-body {
  padding: 4px 16px 16px;
  border-top: 1px solid var(--border-soft);
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.7;
}
.collapse-body p { margin: 10px 0; }
.collapse-body strong { color: var(--text); font-weight: 600; }
.collapse-body .rule {
  display: flex;
  gap: 14px;
  padding: 10px 0;
  border-bottom: 1px dashed var(--border-soft);
}
.collapse-body .rule:last-child { border-bottom: none; }
.collapse-body .rule-trigger {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--signal);
  width: 110px;
  flex-shrink: 0;
  padding-top: 2px;
}
.collapse-body .rule-action { flex: 1; color: var(--text); }
.banned-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 8px;
  margin-top: 10px;
}
.banned-grid span {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--text-mute);
  padding: 8px 10px;
  border: 1px dashed var(--border);
  background: var(--bg);
  text-align: center;
  text-transform: lowercase;
  letter-spacing: 0.02em;
  position: relative;
}
.banned-grid span::before {
  content: '✕';
  color: var(--signal);
  margin-right: 6px;
  font-size: 10px;
}

/* ---------- rules card ---------- */
.rules-card {
  margin: 20px 0;
  padding: 18px 18px 16px;
  background: var(--surface);
  border: 1px solid var(--border-soft);
  border-left: 2px solid var(--accent);
}
.rules-card-hd {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 12px;
}
.rules-card ul {
  margin: 0;
  padding: 0;
  list-style: none;
  font-family: var(--serif);
}
.rules-card li {
  padding: 6px 0;
  font-size: 17px;
  font-weight: 300;
  letter-spacing: -0.005em;
  color: var(--text);
  position: relative;
  padding-left: 20px;
}
.rules-card li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: var(--accent);
}

/* ---------- progress bar (sticky bottom) ---------- */
.prog {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: rgba(8, 9, 10, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-top: 1px solid var(--border);
  z-index: 80;
  padding-bottom: env(safe-area-inset-bottom, 0);
}
.prog-inner {
  max-width: 720px;
  margin: 0 auto;
  padding: 12px var(--pad);
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 14px;
  align-items: center;
}
.prog-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-mute);
}
.prog-track {
  height: 4px;
  background: var(--surface);
  position: relative;
  overflow: hidden;
  border: 1px solid var(--border-soft);
}
.prog-fill {
  position: absolute;
  inset: 0 auto 0 0;
  background: linear-gradient(90deg, var(--accent-dim), var(--accent));
  width: 0%;
  transition: width 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.prog-pct {
  font-family: var(--serif);
  font-size: 18px;
  font-weight: 400;
  color: var(--text);
  min-width: 50px;
  text-align: right;
  line-height: 1;
}
.prog-pct.complete { color: var(--moss); }
.prog-btn {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-mute);
  width: 36px;
  height: 36px;
  font-family: var(--mono);
  font-size: 13px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}
.prog-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ---------- modal ---------- */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 100;
  display: none;
  align-items: flex-start;
  justify-content: center;
  padding: 60px 16px 40px;
  overflow-y: auto;
}
.modal-overlay.open { display: flex; }
.modal {
  width: 100%;
  max-width: 460px;
  background: var(--bg-elev);
  border: 1px solid var(--border);
  position: relative;
  margin: auto 0;
}
.modal-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 18px;
  border-bottom: 1px solid var(--border-soft);
}
.modal-hd h3 {
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 400;
  margin: 0;
  letter-spacing: -0.005em;
}
.modal-close {
  background: transparent;
  border: 1px solid var(--border);
  color: var(--text-mute);
  width: 30px; height: 30px;
  font-family: var(--mono);
