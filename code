    full: [
      { id: 'walk', text: '45–60 min easy walk' },
      { id: 'mob', text: '10 min mobility', rounds: ['Calves','Hamstrings','Hips','Thoracic','Shoulders'], detail: 'Hit all five regions.' },
    ],
    reduced: [
      { id: 'walk-r', text: '30 min easy walk' },
      { id: 'mob-r', text: '10 min mobility', rounds: ['Calves','Hamstrings','Hips','Thoracic','Shoulders'] },
    ],
  },
};

function getPlan(day) {
  let p = TRAINING_PLANS[day];
  if (typeof p === 'string') p = TRAINING_PLANS[p];
  return p;
}

const MORNING_TRIGGER = [
  { id: 'm-baby',   text: 'Baby is settled' },
  { id: 'm-water',  text: 'Drink 24 oz plain water', detail: 'Plain. No additions.' },
  { id: 'm-lmnt',   text: 'Drink 1 full LMNT packet in 20 oz water', detail: 'Equivalent acceptable: ~1000 mg sodium. No half servings.' },
  { id: 'm-coffee', text: 'Coffee (optional)', detail: 'Black only — or splash of heavy cream. Nothing else.' },
  { id: 'm-go',     text: 'Begin training within 15 minutes' },
];

const MEALS = [
  { id: 'meal-bf', timeLabel: 'Post-Train', timeSub: 'within 60m', items: [
    '3 whole eggs',
    '300g egg whites',
    '1 apple',
  ]},
  { id: 'meal-mm', timeLabel: 'Mid-Morn', timeSub: '', items: [
    'Protein shake in water — minimum 40g protein',
  ]},
  { id: 'meal-ln', timeLabel: 'Lunch', timeSub: '', items: [
    '8 oz cooked chicken breast',
    '1 cup cooked jasmine rice',
    'Broccoli',
    'Salt freely',
  ]},
  { id: 'meal-aft', timeLabel: 'Afternoon', timeSub: '', items: 'SNACK', note: 'Set in Settings — choose one option and commit for 30 days.' },
  { id: 'meal-dn', timeLabel: 'Dinner', timeSub: '', items: [
    '8–10 oz lean beef / venison / elk',
    '1 medium sweet potato',
    'Green vegetable',
  ]},
];

const BANNED = ['cereal','chips','cookies','candy','pastries','ice cream','soda','juice','fast food','office snacks','"just one bite"'];

/* ============================================================
   RENDERING
   ============================================================ */

function el(tag, attrs, ...children) {
  const e = document.createElement(tag);
  if (attrs) {
    for (const k in attrs) {
      if (k === 'class') e.className = attrs[k];
      else if (k === 'html') e.innerHTML = attrs[k];
      else if (k.startsWith('on')) e.addEventListener(k.slice(2), attrs[k]);
      else if (k === 'dataset') Object.assign(e.dataset, attrs[k]);
      else e.setAttribute(k, attrs[k]);
    }
  }
  for (const c of children) {
    if (c == null) continue;
    if (typeof c === 'string') e.appendChild(document.createTextNode(c));
    else e.appendChild(c);
  }
  return e;
}

function renderTaskItem(task, isReducedMode) {
  const today = getToday();
  const checked = !!today.checks[task.id];

  const box = el('div', { class: 'task-box' });
  const text = el('div', { class: 'task-text', html: `<strong>${task.text}</strong>` });
  const main = el('div', { class: 'task-main' }, text);
  if (task.detail) main.appendChild(el('div', { class: 'task-detail' }, task.detail));
  if (task.rounds) {
    const rd = el('div', { class: 'task-rounds' });
    rd.appendChild(el('div', { class: 'task-rounds-hd' }, 'Execute:'));
    const ul = el('ul');
    task.rounds.forEach(r => ul.appendChild(el('li', null, r)));
    rd.appendChild(ul);
    main.appendChild(rd);
  }
  const row = el('div', { class: 'task' + (checked ? ' checked' : ''), dataset: { id: task.id }, onclick: () => toggleCheck(task.id) }, box, main);
  return row;
}

function renderMorningSection() {
  const sec = el('section', { class: 'section' });
  const head = el('div', { class: 'section-head' },
    el('div', { class: 'section-head-left' },
      el('div', { class: 'section-num' }, '01 //'),
      el('h2', { class: 'section-title' }, 'Morning ', el('em', null, 'trigger'))
    ),
    el('div', { class: 'section-tag' }, 'On wake')
  );
  sec.appendChild(head);
  const body = el('div', { class: 'section-body' });
  MORNING_TRIGGER.forEach(t => body.appendChild(renderTaskItem(t)));
  sec.appendChild(body);
  return sec;
}

function renderTrainingSection() {
  const today = getToday();
  const day = dayName();
  const plan = getPlan(day);
  const mode = today.sleep === 'yes' ? 'full' : 'reduced';
  const items = plan[mode];

  const sec = el('section', { class: 'section' });
  const head = el('div', { class: 'section-head' },
    el('div', { class: 'section-head-left' },
      el('div', { class: 'section-num' }, '02 //'),
      el('h2', { class: 'section-title' }, 'Training ', el('em', null, '/ ' + plan.mission.toLowerCase()))
    ),
    el('div', { class: 'section-tag ' + mode }, mode === 'full' ? 'Full' : 'Reduced')
  );
  sec.appendChild(head);
  const body = el('div', { class: 'section-body' });
  items.forEach(t => body.appendChild(renderTaskItem(t)));
  sec.appendChild(body);
  return sec;
}

function renderMealItem(meal) {
  const today = getToday();
  const checked = !!today.checks[meal.id];

  let listHTML = '';
  if (meal.items === 'SNACK') {
    const snack = store.settings.snack;
    if (snack === 'yogurt') listHTML = '<span class="b">·</span>Plain Greek yogurt';
    else if (snack === 'eggs') listHTML = '<span class="b">·</span>2 hard-boiled eggs';
    else listHTML = '<span style="color:var(--signal)">⚠ Choose option in Settings</span>';
  } else {
    listHTML = meal.items.map(i => `<div><span class="b">·</span>${i}</div>`).join('');
  }

  const box = el('div', { class: 'task-box' });
  const body = el('div', { class: 'meal-body' });
  body.appendChild(el('div', { class: 'meal-list', html: listHTML }));
  if (meal.note) body.appendChild(el('div', { class: 'meal-note' }, meal.note));

  const content = el('div', { class: 'meal-content' }, box, body);
  const time = el('div', { class: 'meal-time', html: `<b>${meal.timeLabel}</b>${meal.timeSub}` });
  const row = el('div', { class: 'meal-item' + (checked ? ' checked' : ''), dataset: { id: meal.id }, onclick: () => toggleCheck(meal.id) }, time, content);
  return row;
}

function renderMealsSection() {
  const sec = el('section', { class: 'section' });
  const head = el('div', { class: 'section-head' },
    el('div', { class: 'section-head-left' },
      el('div', { class: 'section-num' }, '03 //'),
